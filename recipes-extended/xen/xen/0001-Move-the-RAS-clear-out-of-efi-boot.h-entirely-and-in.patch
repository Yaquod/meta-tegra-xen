From 9449500d17815d0c1349c7f58e94850ee268e923 Mon Sep 17 00:00:00 2001
From: Ahmed Wafdy <ahmedadelwafdy782@gmail.com>
Date: Sun, 1 Mar 2026 00:17:11 +0000
Subject: [PATCH] Move the RAS clear out of efi-boot.h entirely and into
 tegra234_init()

---
 xen/arch/arm/efi/efi-boot.h       | 49 +++++++++++--------------------
 xen/arch/arm/platforms/tegra234.c | 36 ++++++++++++++++++++++-
 2 files changed, 52 insertions(+), 33 deletions(-)

diff --git a/xen/arch/arm/efi/efi-boot.h b/xen/arch/arm/efi/efi-boot.h
index 57cb3e970c..ccd32cb069 100644
--- a/xen/arch/arm/efi/efi-boot.h
+++ b/xen/arch/arm/efi/efi-boot.h
@@ -392,40 +392,25 @@ static void __init efi_arch_process_memory_map(EFI_SYSTEM_TABLE *SystemTable,
 static void __init efi_arch_pre_exit_boot(void)
 {
 #ifdef CONFIG_ARM_64
-    /*
-     * Tegra234 workaround: consume pending SError before ExitBootServices.
-     * We must unmask SError briefly at EL2 to take any pending SError,
-     * then immediately re-mask. This prevents ATF from seeing it during
-     * el3_exit ERET with SCR_EL3.EA=1.
+   /*
+     * Drain any pending SError before ExitBootServices on Tegra234.
+     * A pending CCPMU RAS SError, if taken at EL3 during ATF's ERET
+     * with SCR_EL3.EA=1, will trigger ATF's fatal error handler.
+     * Briefly unmask SError at EL2 to consume it here instead.
+     *
+     * DSB before unmask ensures all prior memory transactions complete
+     * so no new SErrors are generated by in-flight operations.
      */
-    {
-    	volatile uint64_t *err_status = (volatile uint64_t *)0x0E001010UL;
-	volatile uint64_t *err_addr = (volatile uint64_t *)0x0E001018UL;
-	uint64_t status = *err_status;
-
-	if (status & (1ULL << 30)) {
-	    printk(XENLOG_WARNING
-		   "Tegra234: clearing stale CCPMU RAS "
-		   "status=0x%016llx addr=0x%016llx\n",
-		  (unsigned long long)status,(unsigned long long)*err_addr);
-	    *err_status = (1ULL << 31) | (1ULL << 30); /* w1c AV|V */
-	    *err_addr   = 0ULL;
-	}
-    }
-    /* ensure MMIO write is visible, then drain any latched SError */
     asm volatile(
-        "dsb sy\n\t"
-        "isb\n\t"
-        "msr daifclr, #4\n\t"
-        "isb\n\t"
-	"dsb sy\n\t"
-        "nop\n\t"
-        "nop\n\t"
-	"nop\n\t"
-	"nop\n\t"
-        "msr daifset, #4\n\t"
-        "isb\n\t"
-        "dsb sy\n\t"
+        "dsb sy          \n\t"  /* complete all memory accesses */
+        "isb             \n\t"  /* synchronize context */
+        "msr daifclr, #4 \n\t"  /* unmask SError (A bit) */
+        "isb             \n\t"  /* ensure unmask takes effect */
+        "dsb sy          \n\t"  /* consume any pending SError */
+        "nop             \n\t"  /* speculation barrier */
+        "nop             \n\t"
+        "msr daifset, #4 \n\t"  /* re-mask SError */
+        "isb             \n\t"  /* synchronize */
         ::: "memory"
     );
 #endif /* CONFIG_ARM_64 */
diff --git a/xen/arch/arm/platforms/tegra234.c b/xen/arch/arm/platforms/tegra234.c
index f90c93d049..b69f7b123f 100644
--- a/xen/arch/arm/platforms/tegra234.c
+++ b/xen/arch/arm/platforms/tegra234.c
@@ -31,13 +31,47 @@
 #define TEGRA234_BPMP_BASE	 0x0d000000UL
 #define TEGRA234_BPMP_SIZE	 0x00800000UL
 
+#define TEGRA234_CCPMU_BASE      0x0E001000UL
+#define TEGRA234_CCPMU_SIZE      0x00001000UL
+#define CCPMU_ERR0STATUS_OFF     0x010
+#define CCPMU_ERR0ADDR_OFF       0x018
+#define CCPMU_ERR_STATUS_V       (1ULL << 30)  /* Valid */
+#define CCPMU_ERR_STATUS_AV      (1ULL << 31)  /* Address Valid */
+
 static int __init tegra234_init(void)
 {
+    void __iomem *ccpmu;
+    uint64_t status;
+
     printk(XENLOG_INFO
-	   "Xen: Initilaizing NVIDIA Tegra234 (Jetson Orin) Platform\n");
+	   "Xen: Initializing NVIDIA Tegra234 (Jetson Orin) Platform\n");
     printk(XENLOG_INFO 
 	  "Xen: UART @ 0x%08lx, GICD @ 0x%08lx, GICR @ 0x%08lx\n",
   	  TEGRA234_UART_BASE, TEGRA234_GICD_BASE, TEGRA234_GICR_BASE);
+    ccpmu = ioremap_nocache(TEGRA234_CCPMU_BASE, TEGRA234_CCPMU_SIZE);
+    if ( !ccpmu )
+    {
+        printk(XENLOG_WARNING "Tegra234: failed to map CCPMU — stale RAS not cleared\n");
+        return 0; /* non-fatal, but expect possible SDEI issues */
+    }
+
+    status = readq(ccpmu + CCPMU_ERR0STATUS_OFF);
+    if ( status & CCPMU_ERR_STATUS_V )
+    {
+        printk(XENLOG_WARNING
+               "Tegra234: clearing stale CCPMU RAS status=0x%016llx addr=0x%016llx\n",
+               (unsigned long long)status,
+               (unsigned long long)readq(ccpmu + CCPMU_ERR0ADDR_OFF));
+
+        /* W1C: write 1 to AV and V to clear */
+        writeq(CCPMU_ERR_STATUS_AV | CCPMU_ERR_STATUS_V,
+               ccpmu + CCPMU_ERR0STATUS_OFF);
+        writeq(0ULL, ccpmu + CCPMU_ERR0ADDR_OFF);
+
+        dsb(sy);
+    }
+
+    iounmap(ccpmu);
     return 0;
 }
 
