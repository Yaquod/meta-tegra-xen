/dts-v1/;
/plugin/;

/*
 * Xen Dom0 Device Tree Overlay for Jetson Orin Nano (p3768+p3767-0000)
 *
 * Hardware: Orin Nano 6-core (Cortex-A78AE)
 * Core bitmap from MCE FW: 0xcf = 0b11001111
 *   Cluster 0: cores 0-3 present  (mpidr 0x000, 0x100, 0x200, 0x300)
 *   Cluster 1: NO cores present   (mpidr 0x10000-0x10300 all absent)
 *   Cluster 2: cores 0-1 present  (mpidr 0x20000, 0x20100)
 *              cores 2-3 absent   (mpidr 0x20200, 0x20300)
 *
 */

/ {
    compatible = "nvidia,p3768-0000+p3767-0000", "nvidia,p3767-0000",
                 "nvidia,tegra234";

    /* UART fix */
    fragment@0 {
        target-path = "/bus@0/serial@3100000";
        __overlay__ {
            /delete-property/ resets;
            /delete-property/ reset-names;
            status = "okay";
        };
    };

    /* IOMMU disable (Xen manages SMMU directly) */
    fragment@1 {
        target-path = "/bus@0/iommu@12000000";
        __overlay__ { status = "disabled"; };
    };
    fragment@2 {
        target-path = "/bus@0/iommu@10000000";
        __overlay__ { status = "disabled"; };
    };
    fragment@3 {
        target-path = "/bus@0/iommu@8000000";
        __overlay__ { status = "disabled"; };
    };

    /*
     * Cluster 1 CPU nodes entirely absent on Orin Nano 6-core
     *
     * MCE FW core_present_bitmap bits[7:4] = 0 (all absent).
     * These nodes must be disabled so Xen never issues PSCI CPU_ON
     * for MPIDRs 0x10000/0x10100/0x10200/0x10300.
     *
     * Node names confirmed from extracted DTB:
     *   cpu@10000, cpu@10100, cpu@10200, cpu@10300
     */
    fragment@4 {
        target-path = "/cpus/cpu@10000";
        __overlay__ { status = "disabled"; };
    };
    fragment@5 {
        target-path = "/cpus/cpu@10100";
        __overlay__ { status = "disabled"; };
    };
    fragment@6 {
        target-path = "/cpus/cpu@10200";
        __overlay__ { status = "disabled"; };
    };
    fragment@7 {
        target-path = "/cpus/cpu@10300";
        __overlay__ { status = "disabled"; };
    };

    /*
     *
     * MCE FW core_present_bitmap bits[9:8] = 0 (absent).
     * Cluster 2 cores 0-1 (cpu@20000, cpu@20100) ARE present and
     * must remain enabled — they are CPU4 and CPU5 in Dom0.
     *
     */
    fragment@8 {
        target-path = "/cpus/cpu@20200";
        __overlay__ { status = "disabled"; };
    };
    fragment@9 {
        target-path = "/cpus/cpu@20300";
        __overlay__ { status = "disabled"; };
    };
};