+/**
+  Boots Xen hypervisor with Multiboot2 protocol
+
+  @param[in]  ImageHandle       Handle of this application
+  @param[in]  DeviceHandle      The handle of partition where this file lives on.
+  @param[in]  BootOption        Boot options to load
+
+  @retval EFI_SUCCESS    The operation completed successfully.
+
+**/
+STATIC
+EFI_STATUS
+EFIAPI
+ExtLinuxBootXen (
+  IN EFI_HANDLE            ImageHandle,
+  IN EFI_HANDLE            DeviceHandle,
+  IN EXTLINUX_BOOT_OPTION  *BootOption
+  )
+{
+  EFI_STATUS Status;
+  VOID    *Xenbase = NULL;
+  UINTN   XenSize;
+  VOID    *MbiAddress = NULL;
+  CHAR16  *Dom0Cmdline = NULL;
+  VOID    *Dom0Kernel = NULL;
+  UINTN   Dom0KernelSize;
+  VOID    *Initrd = NULL;
+  UINTN   InitrdSize;
+  VOID    *Dtb = NULL;
+  UINTN   DtbSize;
+  VOID    *EntryPoint = NULL;
+
+  DEBUG((DEBUG_ERROR,"%a: Loading Xen Hypervisor Binary\n",__FUNCTION__));
+  if(BootOption->XenPath == NULL){
+    ErrorPrint(L"%a: No Xen Path Specified\n",__FUNCTION__);
+    return EFI_INVALID_PARAMETER;
+  }
+
+
+  Status = OpenAndReadFileToBuffer (
+               DeviceHandle,
+               BootOption->XenPath,
+               NULL,
+               &Xenbase,
+               &XenSize
+               );
+    if (EFI_ERROR (Status)) {
+      ErrorPrint (L"%a: Failed to load Xen from  %s : %r \n", __FUNCTION__, BootOption->XenPath, Status);
+      goto Exit;
+    }
+  
+    if (!IsMultiboot2Image(Xenbase,XenSize)) {
+        ErrorPrint (L"%a: %s Is Not Multiboot2 Image\n", __FUNCTION__, BootOption->XenPath);
+        Status = EFI_UNSUPPORTED;
+        goto Exit;
+    }
+
+    // LinuxPath is Dom0Kernel
+    if (BootOption->LinuxPath == NULL) {
+      ErrorPrint(L"%a: No Dom0Kernel Specified\n",__FUNCTION__);
+      Status = EFI_INVALID_PARAMETER;
+      goto Exit;
+    }
+
+    Status = OpenAndReadFileToBuffer (
+               DeviceHandle,
+               BootOption->LinuxPath,
+               NULL,
+               &Dom0Kernel,
+               &Dom0KernelSize
+               );
+    if (EFI_ERROR (Status)) {
+      ErrorPrint (L"%a: Failed to load Dom0 Kernel from  %s : %r \n", __FUNCTION__, BootOption->LinuxPath, Status);
+      goto Exit;
+    }
+
+    if(BootOption->InitrdPath != NULL){
+       Status = OpenAndReadFileToBuffer (
+               DeviceHandle,
+               BootOption->InitrdPath,
+               NULL,
+               &Initrd,
+               &InitrdSize
+               );
+      if (EFI_ERROR (Status)) {
+        ErrorPrint (L"%a: Failed to load Initrd: %r\n", __FUNCTION__, Status);
+        goto Exit;
+      }
+    }
+
+    if(BootOption->DtbPath != NULL){
+       Status = OpenAndReadFileToBuffer (
+               DeviceHandle,
+               BootOption->DtbPath,
+               NULL,
+               &Dtb,
+               &DtbSize
+               );
+      if (EFI_ERROR (Status)) {
+        ErrorPrint (L"%a: Failed to load Dtb : %r\n", __FUNCTION__, Status);
+        goto Exit;
+      }
+    }
+
+    Dom0Cmdline = BootOption->BootArgs;
+    Status = BuildMultiboot2Info(
+        &MbiAddress,
+        NULL,
+        Dom0Kernel,
+        Dom0KernelSize,
+        Dom0Cmdline,
+        Initrd,
+        InitrdSize,
+        Dtb,
+        DtbSize);
+
+    if (EFI_ERROR (Status)) {
+        ErrorPrint (L"%a: Failed to build Multiboot2 Info : %r\n", __FUNCTION__, Status);
+        goto Exit;
+      }
+
+   Status = GetMultiboot2Entry(
+       Xenbase,
+       XenSize,
+      &EntryPoint);
+
+     if (EFI_ERROR (Status)) {
+        ErrorPrint (L"%a: Failed to get Xen Entry Point: %r\n", __FUNCTION__, Status);
+        goto Exit;
+      }
+
+     Print(L"%a: Starting Xen hypervisor at 0x%016lx\n",(UINT64)(UINTN)EntryPoint);
+     Print(L"%a: Dom0 Kernel : %s\n",BootOption->LinuxPath);
+
+     if(BootOption->InitrdPath != NULL){
+       Print(L"%a: Initrd : %s\n",BootOption->InitrdPath);
+     }
+
+     if(BootOption->DtbPath != NULL){
+       Print(L"%a: Device Tree : %s\n",BootOption->DtbPath);
+     }
+
+     // Wait to read messages
+     gBS->Stall(2000);
+     JumpToMultiboot2(EntryPoint,MbiAddress,MULTIBOOT2_BOOTLOADER_MAGIC);
+
+     ErrorPrint(L"%a: Xen returned unexpectdly\n",__FUNCTION__);
+     Status = EFI_DEVICE_ERROR;
+
+Exit:
+     if(Xenbase != NULL){
+       FreePool(Xenbase);
+     }
+     if (Dom0Kernel != NULL) {
+       FreePool(Dom0Kernel);
+     }
+     if (Initrd != NULL){
+       FreePool(Initrd);
+     }
+     if (Dtb != NULL) {
+       FreePool(Dtb);
+     }
+     if (MbiAddress != NULL) {
+       FreePages(MbiAddress,EFI_SIZE_TO_PAGES(65536));
+     }
+
+     return Status;
+}
+
 /**
   Boots an android style partition located with Partition base name and bootchain
 
