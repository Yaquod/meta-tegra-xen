+
+#include "L4TMultiboot.h"
+#include <Library/BaseMemoryLib.h>
+#include <Library/PrintLib.h>
+
+#define ALIGN_UP(x, align) (((x) + ((align) - 1)) & ~((align) - 1))
+
+/**
+  Convert CHAR16 string to ASCII (for Multiboot2).
+
+  @param[in]  Source    Wide character string.
+  @param[out] Dest      ASCII buffer (must be pre-allocated).
+  @param[in]  DestSize  Size of destination buffer.
+
+  @retval Length of resulting ASCII string.
+**/
+STATIC
+UINTN
+UnicodeToASCII(		
+  IN CONST CHAR16 *Source,
+  OUT CHAR8  *Dest,
+  IN  UINTN DestSize
+){
+UINTN Index;
+for(Index = 0;(Index < DestSize - 1) && (Source[Index] != L'\0');Index++) {
+	Dest[Index] = (CHAR8)Source[Index];
+}
+Dest[Index] = L'\0';
+return Index;
+}
+
+/**
+  Detect if an image is a valid Multiboot2 executable.
+
+  Searches first 32KB for Multiboot2 header (spec allows 0-8192 bytes,
+  we extend for safety).
+
+  @param[in]  ImageBase   Base address of the image in memory.
+  @param[in]  ImageSize   Size of the image in bytes.
+
+  @retval TRUE   Image contains valid Multiboot2 header.
+  @retval FALSE  Not a Multiboot2 image.
+**/
+BOOLEAN
+EFIAPI
+IsMultiboot2Image(
+  IN  VOID *ImageBase,
+  IN  UINTN ImageSize
+    ){
+  MULTIBOOT2_HEADER *Header;
+  UINTN SearchLimit,Offset;
+  UINT32 Checksum;
+
+  if(ImageBase == NULL || (ImageSize < sizeof(MULTIBOOT2_HEADER))) {
+    return FALSE;
+  }
+
+  // Search for the first 32KB
+  SearchLimit = (ImageSize < 32768) ? ImageSize : 32768;
+  SearchLimit -= sizeof(MULTIBOOT2_HEADER);
+
+  for(Offset = 0; Offset <= SearchLimit; Offset+=8){
+    Header = (MULTIBOOT2_HEADER *)((UINT8 *)ImageBase + Offset);
+    
+    // validate header magic
+    if(Header->Magic == MULTIBOOT2_HEADER_MAGIC) {
+      Checksum = Header->Magic + Header->Archticture + Header->HeaderLength + Header->Checksum;
+      if (Checksum == 0) {
+        DEBUG((
+              DEBUG_INFO,
+              "%a: Found a valid Multiboot2 header at offset 0x%x\n",
+              __FUNCTION__,
+              Offset
+              ));
+        return TRUE;
+    }
+  }
+}
+  DEBUG((DEBUG_WARN,"%a: No Multiboot2 header found\n",__FUNCTION__ ));
+  return FALSE;
+}
+
+/**
+  Add a string tag to Multiboot2 info structure.
+
+  @param[in] Current   Current position in MBI buffer.
+  @param[in] Type      Tag type.
+  @param[in] String    Wide character string to add.
+
+  @retval Next position in MBI buffer after this tag.
+**/
+STATIC
+UINT8 *
+AddStringTag(
+    IN  UINT8   *Current,
+    IN  UINT8   Type,
+    IN  CONST CHAR16    *String
+    ){
+  MULTIBOOT2_TAG_STRING* Tag;
+  UINT8 AsciiLen;
+  UINT8 TagSize;
+
+  if (String == NULL) {
+    return Current;
+  }
+
+  Tag = (MULTIBOOT2_TAG_STRING *) Current;
+  Tag->Type = Type;
+
+  AsciiLen = UnicodeToASCII(String,Tag->String, 512);
+
+  // Size is Header + String
+  TagSize = sizeof(UINT32) * 2 + AsciiLen + 1;
+  TagSize = ALIGN_UP(TagSize,8);
+  Tag->Size = (UINT32)TagSize;
+
+  return Current + TagSize;
+}
+
+/**
+  Add a module tag to Multiboot2 info structure.
+
+  @param[in] Current    Current position in MBI buffer.
+  @param[in] ModBase    Module base address.
+  @param[in] ModSize    Module size.
+  @param[in] ModName    Module name string.
+
+  @retval Next position in MBI buffer after this tag.
+**/
+STATIC
+UINT8 *
+AddModuleTag(
+    IN  UINT8   *Current,
+    IN  VOID    *ModBase,
+    IN  UINTN   ModSize,
+    IN  CONST CHAR16  *ModName
+    ){
+  MULTIBOOT2_TAG_MODULE *Tag;
+  UINTN NameLen;
+  UINTN TagSize;
+
+  Tag = (MULTIBOOT2_TAG_MODULE *) Current;
+  Tag->Type = MULTIBOOT_TAG_TYPE_MODULE;
+  Tag->ModStart = (UINT32)(UINTN)ModBase;
+  Tag->ModEnd = (UINT32)((UINTN)ModBase + ModSize );
+
+  if(ModName != NULL){
+    NameLen = UnicodeToASCII(ModName , Tag->String,256);
+  } else {
+    Tag->String[0] = '\0';
+    NameLen = 0;
+  }
+
+  TagSize = sizeof(MULTIBOOT2_TAG_MODULE) + NameLen;
+  TagSize = ALIGN_UP(TagSize,8);
+  Tag->Size = (UINT32) TagSize;
+
+  DEBUG((
+        DEBUG_INFO,
+        "%a: Module %a 0x%08x-0x%08x\n",
+        __FUNCTION__,
+        Tag->String,
+        Tag->ModStart,
+        Tag->ModEnd
+        ));
+  return Current + TagSize;
+}
+
+/**
+  Add memory map tag to Multiboot2 info structure.
+
+  Converts UEFI memory map to Multiboot2 format.
+
+  @param[in] Current   Current position in MBI buffer.
+
+  @retval Next position in MBI buffer after this tag.
+**/
+STATIC
+UINT8 *
+AddMemoryMapTag(
+  IN  UINT8 *Current
+  ){
+  MULTIBOOT2_TAG_MAP *Tag;
+  EFI_STATUS Status;
+  UINTN MapKey;
+  UINTN DescSize;
+  UINT32 DescVersion;
+  EFI_MEMORY_DESCRIPTOR *MemoryMap;
+  EFI_MEMORY_DESCRIPTOR *Desc;
+  UINTN MemoryMapSize,NumEntries,Index;
+  MULTIBOOT2_MMAP_ENTRY *Entry;
+  
+  // Get UEFI Memory Map
+  MemoryMapSize = 0;
+  Status = gBS->GetMemoryMap(
+      &MemoryMapSize,
+      NULL,
+      &MapKey,
+      &DescSize,
+      &DescVersion
+      );
+
+  MemoryMapSize += 10 * DescSize;
+  MemoryMap = AllocatePool(MemoryMapSize);
+
+  // Validate Memory Map
+  if (MemoryMap == NULL) {
+    DEBUG((DEBUG_ERROR,"%a: Allocate Memory Map Failed\n",__FUNCTION__));
+    return Current;
+  }
+
+  Status = gBS->GetMemoryMap(
+      &MemoryMapSize,
+      MemoryMap,
+      &MapKey,
+      &DescSize,
+      &DescVersion
+      );
+
+  if(EFI_ERROR(Status)){
+    DEBUG((DEBUG_ERROR,"%a: GetMemoryMap Failed : %r\n",__FUNCTION__,Status));
+    FreePool(MemoryMap);
+    return Current;
+  }
+
+  // Build Multiboot2 Memory Map
+  Tag = (MULTIBOOT2_TAG_MAP*)Current;
+  Tag->Type = MULTIBOOT_TAG_TYPE_MMAP;
+  Tag->EntrySize = sizeof(MULTIBOOT2_MMAP_ENTRY);
+  Tag->EntryVersion = 0;
+
+  NumEntries = MemoryMapSize / DescSize;
+  Entry = Tag->Entries;
+
+  for(Index = 0; Index < NumEntries; Index++){
+    Desc = (EFI_MEMORY_DESCRIPTOR*)((UINT8 *) MemoryMap + Index * DescSize);
+
+    Entry->Addr = Desc->PhysicalStart;
+    Entry->Len = EFI_PAGES_TO_SIZE(Desc->NumberOfPages);
+    Entry->Reserved = 0;
+
+    // Convert UEFI to Mutliboot2
+    switch(Desc->Type){
+      case EfiConventionalMemory:
+      case EfiBootServicesCode:
+      case EfiBootServicesData:
+        Entry->Type = MULTIBOOT_MEMORY_AVAILABLE;
+        break;
+
+      case EfiACPIReclaimMemory:
+        Entry->Type = MULTIBOOT_MEMORY_ACPI_RECLAIMABLE;
+        break;
+
+      case EfiACPIMemoryNVS:
+        Entry->Type = MULTIBOOT_MEMORY_NVS;
+        break;
+
+      default:
+        Entry->Type = MULTIBOOT_MEMORY_RESERVED;
+        break;
+    }
+    Entry++;
+  }
+
+  Tag->Size = sizeof(MULTIBOOT2_TAG_MAP) - sizeof(MULTIBOOT2_MMAP_ENTRY) + (NumEntries * sizeof(MULTIBOOT2_MMAP_ENTRY));
+  Tag->Size = ALIGN_UP(Tag->Size,8);
+
+  FreePool(MemoryMap);
+
+  DEBUG((
+        DEBUG_INFO,
+        "%a: Added %u Entries to Memory Map\n",
+        __FUNCTION__,
+        NumEntries
+        ));
+  return Current + Tag->Size;
+}
+
+/**
+  Add EFI system table tag.
+
+  @param[in] Current   Current position in MBI buffer.
+
+  @retval Next position in MBI buffer after this tag.
+**/
+STATIC
+UINT8 *
+AddEFISystemTableTag(
+  IN  UINT8   *Current
+  ){
+  MULTIBOOT2_TAG_EFI64 *Tag;
+
+  Tag = (MULTIBOOT2_TAG_EFI64 *)Current;
+  Tag->Type = MULTIBOOT_TAG_TYPE_EFI64;
+  Tag->Size = sizeof(MULTIBOOT2_TAG_EFI64);
+  Tag->Pointer = (UINT64)(UINTN)gST;
+
+  DEBUG ((
+    DEBUG_INFO,
+    "%a: EFI System Table at 0x%016lx\n",
+    __FUNCTION__,
+    Tag->Pointer
+  ));
+
+  return Current + sizeof(MULTIBOOT2_TAG_EFI64);
+}
+
+/**
+  Build Multiboot2 information structure.
+
+  @param[out] MbiAddress      Pointer to allocated MBI structure.
+  @param[in]  XenCmdline      Xen hypervisor command line (optional).
+  @param[in]  Dom0Kernel      Dom0 kernel image base.
+  @param[in]  Dom0KernelSize  Dom0 kernel size.
+  @param[in]  Dom0Cmdline     Dom0 kernel command line.
+  @param[in]  Initrd          Initial ramdisk base (optional).
+  @param[in]  InitrdSize      Initial ramdisk size.
+  @param[in]  Dtb             Device tree blob base (optional).
+  @param[in]  DtbSize         Device tree blob size.
+
+  @retval EFI_SUCCESS           MBI structure created successfully.
+  @retval EFI_OUT_OF_RESOURCES  Failed to allocate memory.
+  @retval EFI_INVALID_PARAMETER Invalid parameters.
+**/
+EFI_STATUS
+EFIAPI
+BuildMultiboot2Info(
+  OUT VOID    **MbiAddress,
+  IN  CHAR16  *XenCmdline    OPTIONAL,
+  IN  VOID    *Dom0Kernel,
+  IN  UINTN   Dom0KernelSize,
+  IN  CHAR16  *Dom0Cmdline   OPTIONAL,
+  IN  VOID    *Initrd        OPTIONAL,
+  IN  UINTN   InitrdSize,
+  IN  VOID    *Dtb           OPTIONAL,
+  IN  UINTN   DtbSize
+){
+  MULTIBOOT2_INFO *MBI;
+  UINT8 *Current;
+  UINTN MbiSize;
+  MULTIBOOT2_TAG *EndTag;
+
+  // Validate Params
+  if ((MbiAddress == NULL) || (Dom0Kernel == NULL)) {
+    return EFI_INVALID_PARAMETER;
+  }
+
+  // Allocate Generous Upper Bound Memory for MBI
+  MbiSize = 65536;
+  MBI = AllocatePages(EFI_SIZE_TO_PAGES(MbiSize));
+  if(MBI == NULL){
+    return EFI_OUT_OF_RESOURCES;
+  }
+
+  ZeroMem(MBI,MbiSize);
+  Current = (UINT8 *)MBI + sizeof(MULTIBOOT2_INFO);
+
+  // Build Struture
+  Current = AddStringTag(Current,MULTIBOOT_TAG_TYPE_BOOT_LOADER_NAME,L"L4TLauncher");
+
+  if(XenCmdline != NULL){
+    Current = AddStringTag(Current,MULTIBOOT_TAG_TYPE_CMDLINE,XenCmdline);
+  }
+
+  // Build Modules Kernel,Initrd and DTB
+  Current = AddModuleTag(Current,Dom0Kernel,Dom0KernelSize,Dom0Cmdline);
+  
+  if((Initrd != NULL) && (InitrdSize != 0)){
+    Current = AddModuleTag(Current,Initrd,InitrdSize,L"ramdisk");
+  }
+
+  if((Dtb != NULL) && (DtbSize != 0)){
+    Current = AddModuleTag(Current,Dtb,DtbSize,L"devicetree");
+  }
+
+  Current = AddMemoryMapTag(Current);
+  Current = AddEFISystemTableTag(Current);
+
+  EndTag = (MULTIBOOT2_TAG*) Current;
+  EndTag->Type = MULTIBOOT_TAG_TYPE_END;
+  EndTag->Size = 8;
+  Current +=8;
+
+  MBI->TotalSize = (UINT32)((UINTN) Current - (UINTN)MBI);
+  MBI->Reserved = 0;
+
+  DEBUG((
+        DEBUG_INFO,
+        "%a: MBI Structure Total Size : %u bytes\n",
+        __FUNCTION__,
+        MBI->TotalSize
+        ));
+
+  *MbiAddress = MBI;
+  return EFI_SUCCESS;
+}
+
+/**
+  Extract Multiboot2 entry point from image.
+
+  @param[in]  ImageBase   Base address of Multiboot2 image.
+  @param[in]  ImageSize   Size of image.
+  @param[out] EntryPoint  Entry point address.
+
+  @retval EFI_SUCCESS     Entry point extracted.
+  @retval EFI_NOT_FOUND   No entry point tag found.
+**/
+EFI_STATUS
+EFIAPI
+GetMultiboot2Entry(
+  IN VOID  *ImageBase,
+  IN UINTN ImageSize,
+  OUT VOID **EntryPoint
+){
+  MULTIBOOT2_HEADER *Header;
+  UINT8             *TagPtr;
+  UINT32            *Tag;
+  UINTN             Offset;
+  UINTN             SearchLimit;
+
+  SearchLimit = (ImageSize < 32768) ? ImageSize : 32768;
+  SearchLimit -= sizeof(MULTIBOOT2_HEADER);
+
+  for (Offset = 0; Offset <= SearchLimit; Offset += 8) {
+    Header = (MULTIBOOT2_HEADER *)((UINT8 *)ImageBase + Offset);
+
+    if (Header->Magic == MULTIBOOT2_HEADER_MAGIC) {
+      // Found header
+      TagPtr = (UINT8 *)Header + sizeof(MULTIBOOT2_HEADER);
+
+      while ((UINTN)TagPtr < (UINTN)Header + Header->HeaderLength) {
+        Tag = (UINT32 *)TagPtr;
+
+        if (Tag[0] == MULTIBOOT2_HEADER_TAG_END) {
+          break;
+        }
+
+        if (Tag[0] == MULTIBOOT2_HEADER_TAG_ENTRY_ADDRESS_EFI64) {
+          // EFI64 entry point (64-bit)
+          *EntryPoint = (VOID *)(UINTN)(*(UINT64 *)(TagPtr + 8));
+          DEBUG ((
+            DEBUG_INFO,
+            "%a: Found EFI64 entry point at 0x%016lx\n",
+            __FUNCTION__,
+            (UINT64)(UINTN)*EntryPoint
+          ));
+          return EFI_SUCCESS;
+        }
+
+        if (Tag[0] == MULTIBOOT2_HEADER_TAG_ENTRY_ADDRESS) {
+          // Legacy 32-bit entry point
+          *EntryPoint = (VOID *)(UINTN)(*(UINT32 *)(TagPtr + 8));
+          DEBUG ((
+            DEBUG_INFO,
+            "%a: Found legacy entry point at 0x%08x\n",
+            __FUNCTION__,
+            (UINT32)(UINTN)*EntryPoint
+          ));
+          return EFI_SUCCESS;
+        }
+
+        // Move to next tag
+        TagPtr += ALIGN_UP(Tag[1], 8);
+      }
+
+      // No entry point tag
+      *EntryPoint = (VOID *)((UINTN)ImageBase + Offset + Header->HeaderLength);
+      DEBUG ((
+        DEBUG_WARN,
+        "%a: No entry tag, using default 0x%016lx\n",
+        __FUNCTION__,
+        (UINT64)(UINTN)*EntryPoint
+      ));
+      return EFI_SUCCESS;
+    }
+  }
+
+  return EFI_NOT_FOUND;
+}
+
+/**
+  Jump to Multiboot2 entry point (architecture-specific).
+
+  This function does NOT return.
+
+  @param[in]  EntryPoint   Xen hypervisor entry point.
+  @param[in]  MbiAddress   Multiboot2 information structure.
+  @param[in]  Magic        Multiboot2 bootloader magic number.
+**/
+VOID
+EFIAPI
+JumpToMultiboot2(
+  IN VOID  *EntryPoint,
+  IN VOID    *MbiAddress,
+  IN UINT32  Magic
+  ){
+  UINTN   MapKey;
+  UINTN   MemoryMapSize;
+  UINTN   DescSize;
+  UINT32   DescVersion;
+  EFI_STATUS  Status;
+
+  DEBUG((
+        DEBUG_ERROR,
+        "%a: Jumping to Xen at 0x%016lx with Mbi Address at 0x%016lx\n",
+        __FUNCTION__,
+        (UINT64)(UINTN)EntryPoint,
+        (UINT64)(UINTN)MbiAddress
+        ));
+
+  MemoryMapSize = 0;
+  Status = gBS->GetMemoryMap(
+      &MemoryMapSize,
+      NULL,
+      &MapKey,
+      &DescSize,
+      &DescVersion
+      );
+
+
+  Status = gBS->ExitBootServices(gImageHandle, MapKey);
+  if (EFI_ERROR(Status)) {
+   Status = gBS->GetMemoryMap(
+      &MemoryMapSize,
+      NULL,
+      &MapKey,
+      &DescSize,
+      &DescVersion
+      );
+
+   Status = gBS->ExitBootServices(gImageHandle, MapKey);  
+  }
+
+  DisableInterrupts();
+
+#if defined(MDE_CPU_AARCH64)
+  // 0x : Magic , x1 : MBI ADDRESS
+  __asm__ volatile (
+      "mov x0, %0\n"
+      "mov x1, %1\n"
+      "br %2\n"
+      :
+      : "r"((UINT64)Magic), "r"((UINT64)(UINTN)MbiAddress), "r"((UINT64)(UINTN)EntryPoint)
+      : "x0","x1","memory"
+      );
+
+#elif defined(MDE_CPU_X64)
+  // x86-64: EAX = magic, EBX = MBI address
+  __asm__ volatile (
+    "mov %0, %%eax\n"
+    "mov %1, %%ebx\n"
+    "jmp *%2\n"
+    :
+    : "r"(Magic), "r"((UINT32)(UINTN)MbiAddress), "r"(EntryPoint)
+    : "eax", "ebx", "memory"
+  );
+#else
+#error "Unsupported Architecture for Multiboot2"
+#endif
+  CpuDeadLoop();
+}
