diff --git a/plat/nvidia/tegra/common/tegra_bl31_setup.c b/plat/nvidia/tegra/common/tegra_bl31_setup.c
index d1616f6..71a8a4e 100644
--- a/plat/nvidia/tegra/common/tegra_bl31_setup.c
+++ b/plat/nvidia/tegra/common/tegra_bl31_setup.c
@@ -236,20 +236,24 @@ void plat_trusty_set_boot_args(aapcs64_params_t *args)
 void bl31_platform_setup(void)
 {
 	{
-	      uint64_t ccpmu_status = mmio_read_64(TEGRA234_RAS_CCPMU_BASE + ERR_STATUS(0));
-	      uint64_t val = 0ULL;
-	      if (ERR_STATUS_GET_FIELD(ccpmu_status, V) != 0U){
-	         WARN("BL31: stale CCPMU RAS error at startup "
-		      "status=0x%" PRIx64 " addr=0x%" PRIx64 " clearing\n",
-		      ccpmu_status,
-		      mmio_read_64(TEGRA234_RAS_CCPMU_BASE + ERR_ADDR(0)));
-		 ERR_STATUS_SET_FIELD(val, V, 1);
-		 ERR_STATUS_SET_FIELD(val, AV, 1);
-		 mmio_write_64(TEGRA234_RAS_CCPMU_BASE + ERR_STATUS(0), val);
-		 mmio_write_64(TEGRA234_RAS_CCPMU_BASE + ERR_ADDR(0), 0ULL);
-		 dsbsy();
-		 isb();
-	      }      
+		uint64_t status = mmio_read_64(TEGRA234_RAS_CCPMU_BASE + ERR_STATUS(0));
+		if ( ERR_STATUS_GET_FIELD(status, V) != 0U ) {
+			uint64_t w1c = 0ULL;
+			uint64_t addr = mmio_read_64(TEGRA234_RAS_CCPMU_BASE + ERR_ADDR(0));
+			WARN("BL31: late CCPMU clear: status=0x%" PRIx64 " addr=0x%" PRIx64 "\n",
+				status, addr);
+			ERR_STATUS_SET_FIELD(w1c, V, 1);
+			if (ERR_STATUS_GET_FIELD(status, AV) != 0U)
+				ERR_STATUS_SET_FIELD(w1c, AV, 1);
+			if (ERR_STATUS_GET_FIELD(status, UE) != 0U) {
+				ERR_STATUS_SET_FIELD(w1c, UE, 1);
+				ERR_STATUS_SET_FIELD(w1c, UET, 1);
+			}
+			mmio_write_64(TEGRA234_RAS_CCPMU_BASE + ERR_STATUS(0), w1c);
+			mmio_write_64(TEGRA234_RAS_CCPMU_BASE + ERR_ADDR(0), 0ULL);
+			dsbsy();
+			isb();
+		}
 	}
 
 	/*
@@ -288,18 +292,48 @@ void bl31_platform_setup(void)
 /*******************************************************************************
  * Perform any BL3-1 platform runtime setup prior to BL3-1 cold boot exit
  ******************************************************************************/
+
 void bl31_plat_runtime_setup(void)
 {
-	/*
-	 * Platform specific runtime setup
-	 */
-	plat_runtime_setup();
-
-	/*
-	 * Add final timestamp before exiting BL31.
-	 */
-	boot_profiler_add_record("[TF] bl31 exit");
-	boot_profiler_deinit();
+    /*
+     * Tegra234 workaround: mask CCPMU RAS interrupt sources at the IH
+     * before ERET to non-secure world.
+     *
+     * Large EFI AllocatePages calls during Xen kernel loading cause MC
+     * reconfigurations that trigger MCE uCode errors (CCPMU IERR=0x5).
+     * These assert the RAS PPI before the NS-world SDEI handler is
+     * registered, causing ARI timeouts and system halt.
+     *
+     * Mask bits [1:0] (CMU sources) in each core's IH general mask
+     * register. Xen's tegra234_init() will clear ERR0STATUS and then
+     * unmask by calling back via PSCI or leaving the unmask to Dom0.
+     *
+     * For now: mask all IH sources to prevent spurious RAS PPIs during
+     * the EFI boot window. This is safe because:
+     * 1. No legitimate RAS errors are expected during EFI boot.
+     * 2. Errors are still latched in ERR*STATUS for later inspection.
+     * 3. Xen/Dom0 will re-enable via tegra234_ras_init_common() path.
+     */
+    {
+        unsigned int i;
+        for (i = 0U; i < PLATFORM_CORE_COUNT; i++) {
+            /*
+             * ih_write_ras_general_mask() with all-ones masks all
+             * IH interrupt sources for this core.
+             * Offset: (PER_CORE_IH_OFFSET * i) + CORE0_RAS_GENERAL_MASK
+             * = (0x28 * i) + 0x000
+             */
+            ih_write_ras_general_mask(i, ENB_ALL_INTR_SOURCES);
+        }
+        dsbsy();
+        isb();
+    }
+
+    /* Platform specific runtime setup */
+    plat_runtime_setup();
+
+    boot_profiler_add_record("[TF] bl31 exit");
+    boot_profiler_deinit();
 }
 
