+static noinline void __init tegra234_ccpmu_clear(void)
+{
+    uint64_t st = 0ULL;
+    uint64_t w1c = 0ULL;
+
+    asm volatile(
+        "dsb sy\n\t"
+        "isb\n\t"
+        "ldr %0, [%1]\n\t"
+        : "=r" (st)
+        : "r" ((uint64_t)0x0E001010UL)
+        : "memory"
+    );
+
+    if ( st & (1ULL << 30) )
+    {
+        w1c |= (1ULL << 30);
+        if ( st & (1ULL << 31) ) w1c |= (1ULL << 31);
+        if ( st & (1ULL << 29) )
+        {
+            w1c |= (1ULL << 29);
+            w1c |= (st & (3ULL << 10));
+        }
+        if ( st & (1ULL << 27) ) w1c |= (1ULL << 27);
+        if ( st & (1ULL << 26) ) w1c |= (1ULL << 26);
+        if ( st & (1ULL << 23) ) w1c |= (1ULL << 23);
+
+        asm volatile(
+            "str %0, [%1]\n\t"
+            "str xzr, [%2]\n\t"
+            "dsb sy\n\t"
+            "isb\n\t"
+            :
+            : "r" (w1c),
+              "r" ((uint64_t)0x0E001010UL),
+              "r" ((uint64_t)0x0E001018UL)
+            : "memory"
+        );
+    }
+}
