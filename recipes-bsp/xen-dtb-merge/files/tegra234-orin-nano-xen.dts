/dts-v1/;
/plugin/;

/*
 * Xen Dom0 Device Tree Overlay for Jetson Orin Nano (p3768+p3767-0000)
 */

/ {
    compatible = "nvidia,p3768-0000+p3767-0000", "nvidia,p3767-0000",
                 "nvidia,tegra234";
    fragment@0 {
        target-path = "/bus@0/serial@3100000";
        __overlay__ {
            /delete-property/ resets;
            /delete-property/ reset-names;
            status = "okay";
        };
    };

    fragment@1 {
        target-path = "/bus@0/iommu@12000000";
        __overlay__ {
            status = "disabled";
        };
    };

    fragment@2 {
        target-path = "/bus@0/iommu@10000000";
        __overlay__ {
            status = "disabled";
        };
    };

    fragment@3 {
        target-path = "/bus@0/iommu@8000000";
        __overlay__ {
            status = "disabled";
        };
    };
};
