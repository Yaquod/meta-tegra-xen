+            .num_entries = ARRAY_SIZE(tegra234_ras_records_cluster2)
+        }
+    };
+
+    assert(id < ARRAY_SIZE(list));
+
+    if (!tegra_platform_is_fpga() && !tegra_platform_is_silicon()) {
+        return;
+    }
+
+    if (mce_is_cluster_present(id)) {
+        enable_error_detection_for_group(list[id].record,
+                                         list[id].num_entries);
+    }
+
+    /*
+     * Tegra234 workaround: enable_error_detection_for_group() just
+     * wrote ERR_CTLR.UI=1 for the cluster RAS nodes. If any CCPMU
+     * error was latched between our earlier tegra234_ras_clear_ccpmu_registers()
+     * call and this point (e.g. from an MC reconfiguration during
+     * Xen EFI loading), the RAS node immediately asserts its interrupt
+     * wire and the GIC redistributor latches it as pending.
+     *
+     * Fix sequence (order is critical per ARM IHI0069 GICv3 spec):
+     *
+     * Step 1: Clear the interrupt source — write W1C to CCPMU ERR_STATUS
+     *         to deassert the interrupt wire at the RAS node.
+     *         Also zero MISC0/MISC1 per DDI0587D §4.3.5 to ensure the
+     *         node returns to quiescent state.
+     * Step 2: DSB+ISB — ensure the RAS node write completes before
+     *         we touch the GIC.
+     * Step 3: Clear GIC pending state — use gicv3_clear_interrupt_pending()
+     *         to write GICR_ICPENDR0 W1C for both RAS PPIs at this PE's
+     *         redistributor. This removes any pending state that latched
+     *         between the ERR_CTLR write and Step 1.
+     * Step 4: DSB — ensure the GIC write completes.
+     * Step 5: Mask IH sources — prevents future spurious assertions
+     *         until Xen/Dom0 SDEI registration unmasks them.
+     *
+     * Note: gicv3_clear_interrupt_pending() is safe to call here
+     * because tegra_gic_pcpu_init() has already been called for this
+     * CPU earlier in tegra_pwr_domain_on_finish(), so this PE's
+     * redistributor is awake and accessible.
+     */
+    tegra234_ras_clear_ccpmu_registers();
+    dsbsy();
+    isb();
+
+    {
+        unsigned int this_core = plat_my_core_pos();
+
+        gicv3_clear_interrupt_pending(TEGRA234_RAS_PPI_ERI, this_core);
+        gicv3_clear_interrupt_pending(TEGRA234_RAS_PPI_FHI, this_core);
+        dsbsy();
+
+        ih_write_ras_general_mask(this_core, ENB_ALL_INTR_SOURCES);
+        dsbsy();
+        isb();
+    }
+
+    VERBOSE("RAS handling enabled for cluster%d, GIC pending cleared\n", id);
 }
 
