From 7966aad5eafbfb4edad9225da41948f9f39009e7 Mon Sep 17 00:00:00 2001
From: Ahmed Wafdy <ahmedadelwafdy782@gmail.com>
Date: Wed, 25 Feb 2026 10:24:24 +0000
Subject: [PATCH] arm: Add NVIDIA Tegra234 platform support

Signed-off-by: Ahmed Wafdy <ahmedadelwafdy782@gmail.com>
---
 xen/arch/arm/platforms/Makefile   |  1 +
 xen/arch/arm/platforms/tegra234.c | 93 +++++++++++++++++++++++++++++++
 2 files changed, 94 insertions(+)
 create mode 100644 xen/arch/arm/platforms/tegra234.c

diff --git a/xen/arch/arm/platforms/Makefile b/xen/arch/arm/platforms/Makefile
index 8632f4115f..abedb1e9db 100644
--- a/xen/arch/arm/platforms/Makefile
+++ b/xen/arch/arm/platforms/Makefile
@@ -6,6 +6,7 @@ obj-$(CONFIG_ALL32_PLAT) += omap5.o
 obj-$(CONFIG_ALL32_PLAT) += rcar2.o
 obj-$(CONFIG_ALL64_PLAT) += seattle.o
 obj-$(CONFIG_ALL_PLAT)   += sunxi.o
+obj-$(CONFIG_ALL_PLAT)   += tegra234.o
 obj-$(CONFIG_ALL64_PLAT) += thunderx.o
 obj-$(CONFIG_ALL64_PLAT) += xgene-storm.o
 obj-$(CONFIG_ALL64_PLAT) += brcm-raspberry-pi.o
diff --git a/xen/arch/arm/platforms/tegra234.c b/xen/arch/arm/platforms/tegra234.c
new file mode 100644
index 0000000000..9fb6109541
--- /dev/null
+++ b/xen/arch/arm/platforms/tegra234.c
@@ -0,0 +1,93 @@
+/*
+ * NVIDIA Tegra234 (Jetson Orin) platform support
+ *
+ * Copyright (C) 2026 Ahmed Wafdy ahmedadelwafdy782@gmail.com
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published by
+ * the Free Software Foundation; either version 2 of the License, or
+ * (at your option) any later version.
+ */
+
+#include <xen/mm.h>
+#include <xen/vmap.h>
+#include <asm/platform.h>
+#include <asm/io.h>
+
+#define TEGRA234_UART_BASE	0x03100000
+#define TEGRA234_UART_SIZE	0x00010000
+#define TEGRA234_GICD_BASE	0x0f400000
+#define TEGRA234_GICR_BASE	0x0f440000
+#define TEGRA234_SMMU_ISO_BASE	0x10000000 /* Camera/Display */
+#define TEGRA234_SMMU_NISO_BASE	0x12000000 /* GPU/PCIe */
+
+static int __init tegra234_init(void)
+{
+    printk("Xen: Initilaizing NVIDIA Tegra234 (Jetson Orin) Platform\n");
+    return 0;
+}
+
+static int tegra234_specific_mapping(struct domain *d)
+{
+    int ret;
+
+    /* Map UART for Dom0 console */
+    ret = map_mmio_regions(d,gaddr_to_gfn(TEGRA234_UART_BASE),DIV_ROUND_UP(TEGRA234_UART_SIZE, PAGE_SIZE),maddr_to_mfn(TEGRA234_UART_BASE));
+
+    if(ret)
+    {
+	printk(XENLOG_ERR "Failed to map UART for Dom0\n");
+	return ret;
+    }
+
+    return 0;
+}
+
+/*
+ * Blacklist devices that should not be accessible to Dom0
+ * without explicit passthrough configrution
+ */
+static const struct dt_device_match tegra234_blacklist_dev[] __initconst =
+{
+    DT_MATCH_COMPATIBLE("nvidia,ga10b"),		/* Ampere GPU */
+
+    DT_MATCH_COMPATIBLE("nvidia,tegra234-dce"),		/* Display Engine */
+
+    DT_MATCH_COMPATIBLE("nvidia,tegra234-nvenc"),	/* Hardware Video Encoders/Decoders */
+    DT_MATCH_COMPATIBLE("nvidia,tegra234-nvdec"),
+    DT_MATCH_COMPATIBLE("nvidia,tegra234-nvjpg"),
+
+    DT_MATCH_COMPATIBLE("nvidia,tegra234-pva"),		/* Vision and Optical Flow */
+    DT_MATCH_COMPATIBLE("nvidia,tegra234-ofa"),
+
+    DT_MATCH_COMPATIBLE("nvidia,tegra234-vi-thi"),	/* Camera/Video Input */
+
+    {/* sentinel */},
+};
+
+static const char * const tegra234_dt_compat[] __initconst =
+{
+    "nvidia,tegra234",
+    "nvidia,p3768-0000+p3767-0000",  /* Orin Nano DevKit */
+    "nvidia,p3768-0000+p3767-0001",  /* Orin Nano */
+    "nvidia,p3768-0000+p3767-0003",  /* Orin NX 16GB */
+    "nvidia,p3768-0000+p3767-0004",  /* Orin NX 8GB */
+    "nvidia,p3768-0000+p3767-0005",  /* Orin Nano 4GB */
+    NULL
+};
+
+PLATFORM_START(tegra234, "NVIDIA Tegra234")
+    .compatible = tegra234_dt_compat,
+    .init = tegra234_init,
+    .specific_mapping = tegra234_specific_mapping,
+    .blacklist_dev = tegra234_blacklist_dev,
+PLATFORM_END
+
+/*
+ * Local variables:
+ * mode: C
+ * c-file-style: "BSD"
+ * c-basic-offset: 4
+ * indent-tabs-mode: nil
+ * End:
+ */
