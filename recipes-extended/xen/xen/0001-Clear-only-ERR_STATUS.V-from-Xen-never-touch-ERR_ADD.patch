diff --git a/xen/arch/arm/arm64/sdei_entry.S b/xen/arch/arm/arm64/sdei_entry.S
new file mode 100644
index 0000000000..b381a8a0f5
--- /dev/null
+++ b/xen/arch/arm/arm64/sdei_entry.S
@@ -0,0 +1,34 @@
+#include <asm/asm_defns.h>
+
+ENTRY(sdei_asm_handler)
+    /*
+     * ATF calls us with:
+     *   X0 = event number
+     *   X1 = handler arg
+     * We must preserve X2-X17 (caller-saved in SDEI ABI)
+     * and complete via SDEI_EVENT_COMPLETE SMC.
+     */
+    stp     x0,  x1,  [sp, #-96]!
+    stp     x2,  x3,  [sp, #16]
+    stp     x4,  x5,  [sp, #32]
+    stp     x6,  x7,  [sp, #48]
+    stp     x29, x30, [sp, #64]
+
+    /* call C handler: sdei_event_handler_c(event_num, arg) */
+    bl      sdei_event_handler_c
+
+    ldp     x2,  x3,  [sp, #16]
+    ldp     x4,  x5,  [sp, #32]
+    ldp     x6,  x7,  [sp, #48]
+    ldp     x29, x30, [sp, #64]
+    ldp     x0,  x1,  [sp], #96
+
+    /* SDEI_EVENT_COMPLETE with status SDEI_EV_HANDLED=0 */
+        /* SDEI_EVENT_COMPLETE with status SDEI_EV_HANDLED=0 */
+    ldr     x0, =0xC4000025     /* use LDR pseudo-op */
+    mov     x1, #0              /* SDEI_EV_HANDLED */
+    smc     #0
+
+    /* should never return */
+1:  b       1b
+END(sdei_asm_handler)
\ No newline at end of file
diff --git a/xen/arch/arm/efi/efi-boot.h b/xen/arch/arm/efi/efi-boot.h
index ccd32cb069..3290671745 100644
--- a/xen/arch/arm/efi/efi-boot.h
+++ b/xen/arch/arm/efi/efi-boot.h
@@ -392,25 +392,93 @@ static void __init efi_arch_process_memory_map(EFI_SYSTEM_TABLE *SystemTable,
 static void __init efi_arch_pre_exit_boot(void)
 {
 #ifdef CONFIG_ARM_64
-   /*
-     * Drain any pending SError before ExitBootServices on Tegra234.
-     * A pending CCPMU RAS SError, if taken at EL3 during ATF's ERET
-     * with SCR_EL3.EA=1, will trigger ATF's fatal error handler.
-     * Briefly unmask SError at EL2 to consume it here instead.
+    /*
+     * Tegra234: Clear any CCPMU RAS error generated during EFI image
+     * loading, then drain the SError pipeline.
+     *
+     * The CCPMU RAS error is triggered by large DMA/MC operations during
+     * kernel/initrd loading (AllocatePages + read_file). The error is
+     * latched in ERR0STATUS by the time we reach this function.
      *
-     * DSB before unmask ensures all prior memory transactions complete
-     * so no new SErrors are generated by in-flight operations.
+     * We must clear the register AND drain the SError pipeline:
+     * - Clearing the register de-asserts the CCPMU error signal so no
+     *   new SError will be generated after this point.
+     * - Draining consumes any SError already latched in the CPU pipeline.
+     *
+     * Note: In EFI context the CCPMU MMIO region is accessible via
+     * physical address because UEFI firmware identity-maps device memory.
+     * TEGRA234_RAS_CCPMU_BASE = 0x0E001000
+     * ERR0STATUS offset = 0x010, ERR0ADDR offset = 0x018
+     */
+    {
+        volatile uint64_t * const err_status =
+            (volatile uint64_t *)0x0E001010UL;
+        volatile uint64_t * const err_addr =
+            (volatile uint64_t *)0x0E001018UL;
+        uint64_t status;
+        uint64_t w1c = 0ULL;
+
+        /*
+         * DSB+ISB before reading: ensure all prior MC/DMA transactions
+         * from image loading are complete and any resulting CCPMU error
+         * has been latched into ERR0STATUS before we sample it.
+         */
+        asm volatile("dsb sy\n\t isb\n\t" ::: "memory");
+
+        status = *err_status;
+
+        if ( status & (1ULL << 30) ) /* bit 30 = V (Valid) */
+        {
+            printk(XENLOG_WARNING
+                   "Tegra234: EFI pre-exit: CCPMU RAS "
+                   "status=0x%016llx addr=0x%016llx\n",
+                   (unsigned long long)status,
+                   (unsigned long long)*err_addr);
+
+            /* W1C: mirror every set field */
+            w1c |= (1ULL << 30); /* V   */
+            if ( status & (1ULL << 31) )
+                w1c |= (1ULL << 31); /* AV  */
+            if ( status & (1ULL << 29) ) /* UE */
+            {
+                w1c |= (1ULL << 29);
+                w1c |= (status & (3ULL << 10)); /* UET[11:10] */
+            }
+            if ( status & (1ULL << 27) )
+                w1c |= (1ULL << 27); /* OF  */
+            if ( status & (1ULL << 26) )
+                w1c |= (1ULL << 26); /* MV  */
+            if ( status & (1ULL << 23) )
+                w1c |= (1ULL << 23); /* DE  */
+
+            *err_status = w1c;
+            *err_addr   = 0ULL;
+
+            /*
+             * DSB: ensure the W1C write reaches the CCPMU before
+             * we unmask SError below.
+             */
+            asm volatile("dsb sy\n\t isb\n\t" ::: "memory");
+        }
+    }
+
+    /*
+     * Now drain any SError already latched in the CPU pipeline.
+     * The CCPMU clear above ensures no new SError signal is being
+     * asserted, so after this drain the pipeline is clean.
      */
     asm volatile(
-        "dsb sy          \n\t"  /* complete all memory accesses */
-        "isb             \n\t"  /* synchronize context */
-        "msr daifclr, #4 \n\t"  /* unmask SError (A bit) */
-        "isb             \n\t"  /* ensure unmask takes effect */
-        "dsb sy          \n\t"  /* consume any pending SError */
-        "nop             \n\t"  /* speculation barrier */
+        "dsb sy          \n\t"
+        "isb             \n\t"
+        "msr daifclr, #4 \n\t"   /* unmask SError */
+        "isb             \n\t"
+        "dsb sy          \n\t"   /* consume pending SError */
         "nop             \n\t"
-        "msr daifset, #4 \n\t"  /* re-mask SError */
-        "isb             \n\t"  /* synchronize */
+        "nop             \n\t"
+        "nop             \n\t"
+        "nop             \n\t"
+        "msr daifset, #4 \n\t"   /* re-mask SError */
+        "isb             \n\t"
         ::: "memory"
     );
 #endif /* CONFIG_ARM_64 */
@@ -426,6 +494,26 @@ static void __init efi_arch_cfg_file_early(const EFI_LOADED_IMAGE *image,
                                            const char *section)
 {
     union string name;
+    {
+        volatile uint64_t * const s = (volatile uint64_t *)0x0E001010UL;
+        volatile uint64_t * const a = (volatile uint64_t *)0x0E001018UL;
+        uint64_t st;
+        uint64_t w = 0ULL;
+
+        asm volatile("dsb sy\n\t isb\n\t" ::: "memory");
+        st = *s;
+        if ( st & (1ULL << 30) ) {
+            w |= (1ULL << 30);
+            if ( st & (1ULL << 31) ) w |= (1ULL << 31);
+            if ( st & (1ULL << 29) ) {
+                w |= (1ULL << 29);
+                w |= (st & (3ULL << 10));
+            }
+            *s = w;
+            *a = 0ULL;
+            asm volatile("dsb sy\n\t isb\n\t" ::: "memory");
+        }
+    }
 
