+/*
+ * xen/arch/arm/vsdei.c
+ *
+ * Virtual SDEI Dispatcher for Xen guests.
+ * Implements the Virtual SDEI Dispatcher role (EL2 dispatching to EL1).
+ */
+
+#include <xen/lib.h>
+#include <asm/regs.h>
+
+/*
+ * stub: Return NOT_SUPPORTED for all guest SDEI calls.
+ * TODO: will implement full virtual SDEI state machine.
+ */
+bool vsdei_handle_call(struct cpu_user_regs *regs)
+{
+    uint32_t fid = (uint32_t)get_user_reg(regs, 0);
+
+    /*
+     * For now, return SDEI_NOT_SUPPORTED for everything.
+     */
+    printk(XENLOG_WARNING "SDEI: guest call fid=0x%08x denied\n", fid);
+    set_user_reg(regs, 0, (unsigned long)(-1));  /* SDEI_NOT_SUPPORTED */
+
+    return true;
+}
