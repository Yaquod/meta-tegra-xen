diff --git a/xen/arch/arm/sdei.c b/xen/arch/arm/sdei.c
new file mode 100644
index 0000000000..5db77a5296
--- /dev/null
+++ b/xen/arch/arm/sdei.c
@@ -0,0 +1,181 @@
+/*
+ * SDEI (Software Delegated Exception Interface) client for Xen
+ * Implements Physical SDEI Client role (EL2 receiving from EL3 Firmware)
+ *
+ * Per ARM DEN0054C 
+ * Copyright (C) 2026 Ahmed Wafdy ahmedadelwafdy782@gmail.com
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published by
+ * the Free Software Foundation; either version 2 of the License, or
+ * (at your option) any later version.
+ */
+
+#include <xen/init.h>
+#include <xen/lib.h>
+#include <xen/types.h>
+#include <xen/errno.h>
+#include <xen/percpu.h>
+#include <xen/smp.h>
+#include <asm/smccc.h>
+#include <asm/processor.h>
+#include <asm/sdei.h>
+
+DEFINE_PER_CPU(bool, sdei_event_pending);
+DEFINE_PER_CPU(int, sdei_last_event);
+
+static bool sdei_available;
+static uint64_t sdei_firmware_version;
+
+
+/**
+ * Query SDEI firmware version via smc.
+ * This should be called after PSCI/SMCC init. 
+ */
+static int __init sdei_probe(void)
+{
+    struct arm_smccc_res res;
+    arm_smccc_smc(SDEI_VERSION,&res);
+
+    if ((long)res.a0 < 0)
+    {
+        printk(XENLOG_INFO "SDEI: not supported by frimware (ret=%ld)\n",(long)res.a0);
+        return -ENODEV;
+    }
+
+    sdei_firmware_version = res.a0;
+    printk(XENLOG_INFO "SDEI: frimware version %lu.%lu\n", SDEI_VERSION_MAJOR(res.a0), SDEI_VERSION_MINOR(res.a0));
+    sdei_available = true;
+    return 0;
+}
+
+/**
+ * Register an SDEI event handler for a given event number and argument.
+ * This should be called after sdei_probe confirms availability.
+ */
+static int __init sdei_register_event(int event_num, uint64_t handler, uint64_t flags, uint64_t arg)
+{
+    struct arm_smccc_res res;
+    long ret;
+    /*
+     * SDEI_EVENT_REGISTER:
+     * X1 = event_num
+     * X2 = handler address
+     * X3 = handler arg (passed to handler in X1 at dispatch time)
+     * X4 = flags: SDEI_REGF_RM_PE = route to calling PE
+     * X5 = affinity: 0 (ignored for RM_PE, uses calling PE)
+     */
+    arm_smccc_smc(SDEI_EVENT_REGISTER,
+                  event_num,
+                  handler,
+                  arg,             /* X3: handler arg */
+                  SDEI_REGF_RM_PE, /* X4: route to THIS PE */
+                  0,               /* X5: affinity (ignored for RM_PE) */
+                  &res);
+                      
+    ret = (long)res.a0;
+
+    if(ret < 0)
+    {
+        printk(XENLOG_ERR "SDEI: failed to register event %d (ret=%ld)\n", event_num, ret);
+        return (int)ret;
+    }
+
+    // enable the event after successful registration
+    arm_smccc_smc(SDEI_EVENT_ENABLE, event_num, &res);
+    ret = (long)res.a0;
+    if(ret < 0)
+    {
+        printk(XENLOG_ERR "SDEI: failed to enable event %d (ret=%ld)\n", event_num, ret);
+        return (int)ret;
+    }
+
+    printk(XENLOG_INFO "SDEI: successfully registered and enabled event %d\n", event_num);
+    return 0;
+}
+
+/**
+ * Unmask PE to allow SDEI events to be delivered to this PE.
+ */
+static int sdei_unmask_pe(void)
+{
+    struct arm_smccc_res res;
+    arm_smccc_smc(SDEI_PE_UNMASK, &res);
+    if ((long)res.a0 < 0)
+    {
+        printk(XENLOG_ERR "SDEI: failed to unmask PE (ret=%ld)\n", (long)res.a0);
+        return (int)res.a0;
+    }
+    return 0;
+}
+
+/**
+ * Per CPU initialization to unmask SDEI events. This should be called on each CPU after confirming SDEI availability.
+ * Returns 0 on success, negative error code on failure.
+ * If SDEI is not available, returns 0 without doing anything.
+ */
+int sdei_cpu_init(void)
+{
+    int cpu, ret;
+
+    if (!sdei_available)
+        return 0;
+
+    cpu = smp_processor_id();  /* which core am I? */
+
+    /*
+     * Private explicit events are per-PE.
+     * Register THIS core's event (EP_EVENT_BASE + cpu_id).
+     * Must be called on EACH cpu, not just BSP.
+     */
+    ret = sdei_register_event(TEGRA_SDEI_EP_EVENT_BASE + cpu,
+                            (uint64_t)sdei_asm_handler,
+                            SDEI_REGF_RM_PE, /* flags */
+                            0                /* handler arg */);
+    
+    if (ret) {
+        printk(XENLOG_ERR "SDEI: CPU%d event %d register failed\n",
+               cpu, TEGRA_SDEI_EP_EVENT_BASE + cpu);
+        return ret;
+    }
+
+    /* Unmask this PE so events can be delivered */
+    ret = sdei_unmask_pe();
+    if (ret)
+        return ret;
+
+    printk(XENLOG_INFO "SDEI: CPU%d initialized (event %d)\n",
+           cpu, TEGRA_SDEI_EP_EVENT_BASE + cpu);
+    return 0;
+}
+
+int __init sdei_init(void)
+{
+    int ret = sdei_probe();
+    if (ret)
+        return ret;
+
+    return sdei_cpu_init();
+}
+
+/**
+ * SDEI event handler
+ * 
+ * This is where EL3 will dispatch execution when a registered SDEI event
+ * fires.
+ * The handler runs in a constrained environment,
+ * as at the time of the event the state and consistency of the
+ * underlying OS kernel or hypervisor is unknown."
+*/
+void sdei_event_handler_c(unsigned long event_num, unsigned long arg)
+{
+    /* Per-CPU RAS event counter for deferred processing */
+    this_cpu(sdei_event_pending) = true;
+    this_cpu(sdei_last_event) = (int)event_num;
+
+    /*
+     * TODO: Queue work for Dom0 notification
+     * For now, just log at debug level.
+     */
+    printk(XENLOG_DEBUG "SDEI Event triggered: event_num=%lu, arg=%lu\n", event_num, arg);
+}
